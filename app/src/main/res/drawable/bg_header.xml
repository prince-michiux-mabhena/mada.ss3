<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#C0572B"
                android:centerColor="#8B3A1A"
                android:endColor="#5C3D1E"
                android:type="linear"/>
        </shape>
    </item>
    <!-- Kente-inspired decorative stripe -->
    <item android:bottom="0dp" android:top="0dp" android:left="0dp" android:right="0dp">
        <shape android:shape="rectangle">
            <stroke android:width="0dp" android:color="@android:color/transparent"/>
        </shape>
    </item>
</layer-list>
